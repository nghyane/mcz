---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Blog — MCZ" description="Articles about image streaming, web performance, and the MCZ format.">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-serif text-[32px] font-normal text-fg mb-10">Blog</h1>
    {posts.length === 0 && (
      <p class="text-fg3 text-sm">No posts yet.</p>
    )}
    <div class="flex flex-col gap-8">
      {posts.map((post) => (
        <a href={`/blog/${post.id}/`} class="group no-underline block">
          <time class="text-xs text-fg3 font-mono">{post.data.date}</time>
          <h2 class="text-base font-semibold text-fg mt-1 mb-1 group-hover:text-accent transition-colors">{post.data.title}</h2>
          <p class="text-sm text-fg2 leading-relaxed">{post.data.description}</p>
          {post.data.tags && (
            <div class="flex gap-1.5 mt-2">
              {post.data.tags.map((tag: string) => (
                <span class="text-[10px] font-mono text-fg3 bg-bg-sub px-2 py-0.5 rounded">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>
</Base>
