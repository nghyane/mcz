---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";
---

<Base title="Pricing — MCZ" description="Free tools, affordable cloud sharing.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is MCZ free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All tools are open source, run in your browser, no account needed." }},
      { "@type": "Question", "name": "How much storage do I need?", "acceptedAnswer": { "@type": "Answer", "text": "A typical photo gallery is 200-500 MB. Pro (100 GB) fits ~300 galleries. Business (1 TB) fits ~3,000." }},
      { "@type": "Question", "name": "Can I self-host MCZ files?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. MCZ files are static assets. Host them anywhere — S3, R2, any CDN. Cloud plans are for convenience." }},
    ]
  })} />
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="font-serif text-[36px] font-normal text-fg text-center mb-3">Pricing</h1>
    <p class="text-sm text-fg3 text-center mb-14">Free forever. Cloud when you need it.</p>

    <div class="grid grid-cols-3 gap-5 max-[768px]:grid-cols-1">
      <!-- Free -->
      <div class="rounded-[10px] border border-border p-7">
        <p class="text-sm font-medium text-fg mb-1">Free</p>
        <p class="text-[36px] font-bold text-fg leading-none mb-5">$0</p>
        <a href="/creator/" class="block h-9 text-center leading-9 text-[13px] font-medium text-fg bg-bg-sub rounded-lg no-underline transition-colors hover:bg-border mb-6">Get started</a>
        <ul class="text-[13px] text-fg2 flex flex-col gap-2.5">
          <li>✓ Viewer, Creator, Inspector</li>
          <li>✓ CLI + JS SDK</li>
          <li>✓ Unlimited local usage</li>
          <li>✓ Open source (MIT)</li>
        </ul>
      </div>

      <!-- Pro -->
      <div class="rounded-[10px] border border-fg/20 bg-bg-sub p-7">
        <p class="text-sm font-medium text-fg mb-1">Pro</p>
        <p class="text-[36px] font-bold text-fg leading-none mb-5">$5<span class="text-base font-normal text-fg3">/mo</span></p>
        <span class="block h-9 text-center leading-9 text-[13px] font-medium text-white bg-fg rounded-lg cursor-not-allowed opacity-70 mb-6">Coming soon</span>
        <ul class="text-[13px] text-fg2 flex flex-col gap-2.5">
          <li>✓ Everything in Free</li>
          <li>✓ 100 GB cloud storage</li>
          <li>✓ Share links (30-day expiry)</li>
          <li>✓ CDN delivery worldwide</li>
          <li>✓ ZIP download for recipients</li>
        </ul>
      </div>

      <!-- Business -->
      <div class="rounded-[10px] border border-border p-7">
        <p class="text-sm font-medium text-fg mb-1">Business</p>
        <p class="text-[36px] font-bold text-fg leading-none mb-5">$15<span class="text-base font-normal text-fg3">/mo</span></p>
        <span class="block h-9 text-center leading-9 text-[13px] font-medium text-fg bg-bg-sub rounded-lg cursor-not-allowed opacity-70 mb-6">Coming soon</span>
        <ul class="text-[13px] text-fg2 flex flex-col gap-2.5">
          <li>✓ Everything in Pro</li>
          <li>✓ 1 TB cloud storage</li>
          <li>✓ Permanent share links</li>
          <li>✓ Custom slugs</li>
          <li>✓ API access</li>
          <li>✓ Priority support</li>
        </ul>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mt-20 flex flex-col gap-5 text-sm">
      <div class="border-b border-border pb-5">
        <h3 class="font-medium text-fg mb-1">Is free really free?</h3>
        <p class="text-fg3">Yes. All tools are open source, run in your browser, no account needed.</p>
      </div>
      <div class="border-b border-border pb-5">
        <h3 class="font-medium text-fg mb-1">How much storage do I need?</h3>
        <p class="text-fg3">A typical photo gallery is 200-500 MB. Pro (100 GB) fits ~300 galleries. Business (1 TB) fits ~3,000.</p>
      </div>
      <div class="border-b border-border pb-5">
        <h3 class="font-medium text-fg mb-1">Can I self-host instead?</h3>
        <p class="text-fg3">MCZ files are static. Host them anywhere — S3, R2, any CDN. Cloud plans are for convenience.</p>
      </div>
      <div>
        <h3 class="font-medium text-fg mb-1">Need more than 1 TB?</h3>
        <p class="text-fg3"><a href="/contact/" class="text-accent no-underline hover:underline">Contact us</a> for custom plans.</p>
      </div>
    </div>
  </section>
</Base>
