---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";
---

<Base title="Pricing — MCZ" description="Free tools, affordable cloud sharing.">
  <section class="mx-auto max-w-2xl px-6 py-20">
    <h1 class="font-serif text-[36px] font-normal text-fg text-center mb-3">Pricing</h1>
    <p class="text-sm text-fg3 text-center mb-14">Free forever. Cloud when you need it.</p>

    <div class="grid grid-cols-2 gap-5 max-[640px]:grid-cols-1">
      <!-- Free -->
      <div class="rounded-[10px] border border-border p-8">
        <p class="text-sm font-medium text-fg mb-1">Free</p>
        <p class="text-[40px] font-bold text-fg leading-none mb-6">$0</p>
        <a href="/creator/" class="block h-10 text-center leading-10 text-sm font-medium text-fg bg-bg-sub rounded-lg no-underline transition-colors hover:bg-border mb-8">Get started</a>
        <ul class="text-[13px] text-fg2 flex flex-col gap-3">
          <li>✓ Viewer, Creator, Inspector</li>
          <li>✓ CLI + JS SDK</li>
          <li>✓ Unlimited local usage</li>
          <li>✓ Open source (MIT)</li>
        </ul>
      </div>

      <!-- Cloud -->
      <div class="rounded-[10px] border border-fg/20 p-8 bg-bg-sub">
        <p class="text-sm font-medium text-fg mb-1">Cloud</p>
        <p class="text-[40px] font-bold text-fg leading-none mb-6">$3<span class="text-base font-normal text-fg3">/mo</span></p>
        <span class="block h-10 text-center leading-10 text-sm font-medium text-white bg-fg rounded-lg cursor-not-allowed opacity-70 mb-8">Coming soon</span>
        <ul class="text-[13px] text-fg2 flex flex-col gap-3">
          <li>✓ Everything in Free</li>
          <li>✓ 10 GB cloud storage</li>
          <li>✓ Share links via CDN</li>
          <li>✓ API access</li>
        </ul>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mt-20 flex flex-col gap-5 text-sm">
      <div class="border-b border-border pb-5">
        <h3 class="font-medium text-fg mb-1">Is free really free?</h3>
        <p class="text-fg3">Yes. All tools are open source, run in your browser, no account needed.</p>
      </div>
      <div class="border-b border-border pb-5">
        <h3 class="font-medium text-fg mb-1">Can I self-host?</h3>
        <p class="text-fg3">MCZ files are static. Host them anywhere. Cloud is convenience, not lock-in.</p>
      </div>
      <div>
        <h3 class="font-medium text-fg mb-1">Need more storage?</h3>
        <p class="text-fg3">Contact us for custom plans.</p>
      </div>
    </div>
  </section>
</Base>
