---
import "../styles/global.css";
import Base from "../layouts/Base.astro";
---

<Base title="MCZ — Share images that stream like video" description="Bundle photos into one file. Share a link. Images appear instantly. Perfect for photography, e-commerce, portfolios, and publishing.">
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-16 grid grid-cols-[1fr_320px] gap-15 items-center max-[768px]:grid-cols-1 max-[768px]:gap-10 max-[768px]:px-5 max-[768px]:pt-10 max-[768px]:pb-10">
    <div>
      <h1 class="font-serif text-[44px] font-normal leading-[1.1] tracking-[-0.02em] mb-4 max-[768px]:text-[32px]">
        Image container that <em>streams</em> like video
      </h1>
      <p class="text-fg2 text-base leading-relaxed mb-7 max-w-[420px]">
        One file, instant layout, images appear as data arrives. No more waiting for the full download.
      </p>
      <div class="flex gap-2.5 flex-wrap">
        <a href="/playground/#demo" class="h-10 px-5 bg-fg text-white text-[13px] font-medium rounded-lg inline-flex items-center gap-[7px] no-underline transition-colors hover:bg-[#222]">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Try the playground
        </a>
        <a href="/pricing/" class="h-10 px-5 bg-white text-fg text-[13px] font-medium rounded-lg border border-border inline-flex items-center gap-[7px] no-underline transition-colors hover:bg-bg-sub">
          View pricing
        </a>
      </div>
    </div>
    <div class="max-[768px]:max-w-[300px]">
      <div class="relative border border-border rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,.06)]">
        <div class="h-7 bg-bg-sub border-b border-border flex items-center px-2.5 gap-[5px]">
          <div class="w-1.5 h-1.5 rounded-full bg-[#ddd]"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-[#ddd]"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-[#ddd]"></div>
        </div>
        <div class="mockup-pages flex flex-col gap-0.5 p-0.5">
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[100px]"><div class="fill absolute inset-0 bg-[#e0e0e0]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[80px]"><div class="fill absolute inset-0 bg-[#e4e4e4]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[90px]"><div class="fill absolute inset-0 bg-[#e0e0e0]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[85px]"><div class="fill absolute inset-0 bg-[#e8e8e8]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[75px]"><div class="fill absolute inset-0 bg-[#e4e4e4]"></div></div>
        </div>
        <div class="absolute bottom-2 right-2 font-mono text-[9px] font-medium text-[#bbb] bg-white/80 px-1.5 py-0.5 rounded">streaming 3/5</div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-serif text-[28px] font-normal leading-tight text-center mb-8">How it works</h2>
    <div class="grid grid-cols-3 gap-6 max-[640px]:grid-cols-1">
      <div class="text-center">
        <div class="w-10 h-10 rounded-full bg-bg-sub border border-border flex items-center justify-center mx-auto mb-3 text-fg2 font-semibold text-sm">1</div>
        <h3 class="text-sm font-semibold text-fg mb-1">Bundle</h3>
        <p class="text-xs leading-relaxed text-fg3">Drop your images into the Creator. They're packed into a single .mcz file — no quality loss.</p>
      </div>
      <div class="text-center">
        <div class="w-10 h-10 rounded-full bg-bg-sub border border-border flex items-center justify-center mx-auto mb-3 text-fg2 font-semibold text-sm">2</div>
        <h3 class="text-sm font-semibold text-fg mb-1">Share</h3>
        <p class="text-xs leading-relaxed text-fg3">Host the file anywhere or use MCZ Cloud. Send the link — that's it.</p>
      </div>
      <div class="text-center">
        <div class="w-10 h-10 rounded-full bg-bg-sub border border-border flex items-center justify-center mx-auto mb-3 text-fg2 font-semibold text-sm">3</div>
        <h3 class="text-sm font-semibold text-fg mb-1">Stream</h3>
        <p class="text-xs leading-relaxed text-fg3">Recipients see images instantly as data arrives. They can download all as ZIP.</p>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-serif text-[28px] font-normal leading-tight text-center mb-8">Built for</h2>
    <div class="grid grid-cols-3 gap-4 max-[640px]:grid-cols-1">
      <div class="bg-bg-sub rounded-[10px] px-5 py-4">
        <h3 class="text-sm font-semibold text-fg mb-1">Client photo delivery</h3>
        <p class="text-xs text-fg3 leading-relaxed">Stop sending 14 emails or expired WeTransfer links. One link, instant preview, ZIP download.</p>
      </div>
      <div class="bg-bg-sub rounded-[10px] px-5 py-4">
        <h3 class="text-sm font-semibold text-fg mb-1">Product galleries</h3>
        <p class="text-xs text-fg3 leading-relaxed">15 product photos = 15 HTTP requests and layout shift. MCZ loads them in one stream.</p>
      </div>
      <div class="bg-bg-sub rounded-[10px] px-5 py-4">
        <h3 class="text-sm font-semibold text-fg mb-1">Property listings</h3>
        <p class="text-xs text-fg3 leading-relaxed">30+ photos per listing. Buyers see them streaming in, not waiting for a full download.</p>
      </div>
      <div class="bg-bg-sub rounded-[10px] px-5 py-4">
        <h3 class="text-sm font-semibold text-fg mb-1">Lookbooks & catalogs</h3>
        <p class="text-xs text-fg3 leading-relaxed">PDF re-encodes your images. MCZ passes them through untouched — original quality.</p>
      </div>
      <div class="bg-bg-sub rounded-[10px] px-5 py-4">
        <h3 class="text-sm font-semibold text-fg mb-1">Art portfolios</h3>
        <p class="text-xs text-fg3 leading-relaxed">No more "images still loading" on slow gallery sites. MCZ streams on any connection.</p>
      </div>
      <div class="bg-bg-sub rounded-[10px] px-5 py-4">
        <h3 class="text-sm font-semibold text-fg mb-1">Any app with images</h3>
        <p class="text-xs text-fg3 leading-relaxed">3 KB SDK, zero dependencies. Add streaming image galleries to any web app.</p>
      </div>
    </div>
  </section>


  <!-- Comparison -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-serif text-[28px] font-normal leading-tight text-center mb-6">How MCZ compares</h2>
    <div class="border border-border rounded-[10px] overflow-hidden">
      <table class="w-full border-collapse text-[13px]">
        <tr class="bg-bg-sub">
          <th class="text-left font-medium text-fg p-2.5 px-4 border-b border-border"></th>
          <th class="text-left font-medium text-fg p-2.5 px-4 border-b border-border">MCZ</th>
          <th class="text-left font-medium text-fg p-2.5 px-4 border-b border-border">ZIP</th>
          <th class="text-left font-medium text-fg p-2.5 px-4 border-b border-border">PDF</th>
        </tr>
        <tr><td class="p-2.5 px-4 border-b border-border font-medium text-fg">Preview before download</td><td class="p-2.5 px-4 border-b border-border text-success">✓ instant</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td></tr>
        <tr><td class="p-2.5 px-4 border-b border-border font-medium text-fg">Progressive streaming</td><td class="p-2.5 px-4 border-b border-border text-success">✓</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td></tr>
        <tr><td class="p-2.5 px-4 border-b border-border font-medium text-fg">No quality loss</td><td class="p-2.5 px-4 border-b border-border text-success">✓</td><td class="p-2.5 px-4 border-b border-border text-success">✓</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗ re-encodes</td></tr>
        <tr><td class="p-2.5 px-4 font-medium text-fg">View in browser</td><td class="p-2.5 px-4 text-success">✓ stream</td><td class="p-2.5 px-4 text-fg3">✗ download first</td><td class="p-2.5 px-4 text-fg3">✗ slow render</td></tr>
      </table>
    </div>
  </section>

  <!-- For developers -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-serif text-[28px] font-normal leading-tight text-center mb-2">For developers</h2>
    <p class="text-sm text-fg3 text-center mb-6">3 lines to stream images. JS SDK, Rust crate, CLI tool.</p>
    <pre class="bg-bg-sub border border-border rounded-[10px] p-5 font-mono text-xs leading-[1.7] text-fg overflow-x-auto"><span class="text-syn-kw">const</span> mcz = <span class="text-syn-kw">await</span> <span class="text-syn-fn">MCZ.open</span>(url)

<span class="text-syn-kw">for await</span> (<span class="text-syn-kw">const</span> {"{"} index, blob {"}"} <span class="text-syn-kw">of</span> mcz.<span class="text-syn-fn">stream</span>()) {"{"}
  images[index].src = URL.<span class="text-syn-fn">createObjectURL</span>(blob)
{"}"}</pre>
    <p class="text-xs text-fg3 text-center mt-4">
      <a href="https://github.com/nghyane/mcz" class="text-accent no-underline hover:underline">View on GitHub</a>
      <span class="text-border mx-2">·</span>
      <a href="/blog/mcz-format-specification/" class="text-accent no-underline hover:underline">Read the spec</a>
    </p>
  </section>
</Base>

<style>
  @keyframes pg-fill { to { transform: scaleX(1) } }
  .mockup-pages .fill {
    transform: scaleX(0);
    transform-origin: left;
    animation: pg-fill .6s ease forwards;
  }
  .mockup-pages > :nth-child(1) .fill { animation-delay: .3s }
  .mockup-pages > :nth-child(2) .fill { animation-delay: .8s }
  .mockup-pages > :nth-child(3) .fill { animation-delay: 1.3s }
  .mockup-pages > :nth-child(4) .fill { animation-delay: 1.8s }
  .mockup-pages > :nth-child(5) .fill { animation-delay: 2.3s }
</style>


