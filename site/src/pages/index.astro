---
import "../styles/global.css";
import Base from "../layouts/Base.astro";
---

<Base title="MCZ — Image container that streams like video">
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-16 grid grid-cols-[1fr_320px] gap-15 items-center max-[768px]:grid-cols-1 max-[768px]:gap-10 max-[768px]:px-5 max-[768px]:pt-10 max-[768px]:pb-10">
    <div>
      <h1 class="font-serif text-[44px] font-normal leading-[1.1] tracking-[-0.02em] mb-4 max-[768px]:text-[32px]">
        Image container that <em>streams</em> like video
      </h1>
      <p class="text-fg2 text-base leading-relaxed mb-7 max-w-[420px]">
        One file, instant layout, pages appear as data arrives. No more waiting for the full download.
      </p>
      <div class="flex gap-2.5 flex-wrap">
        <a href="/playground/" class="h-10 px-5 bg-fg text-white text-[13px] font-medium rounded-lg inline-flex items-center gap-[7px] no-underline transition-colors hover:bg-[#222]">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Try the playground
        </a>
        <a href="https://github.com/nghyane/mcz" target="_blank" class="h-10 px-5 bg-white text-fg text-[13px] font-medium rounded-lg border border-border inline-flex items-center gap-[7px] no-underline transition-colors hover:bg-bg-sub">
          View on GitHub
        </a>
      </div>
    </div>
    <div class="max-[768px]:max-w-[300px]">
      <div class="relative border border-border rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,.06)]">
        <div class="h-7 bg-bg-sub border-b border-border flex items-center px-2.5 gap-[5px]">
          <div class="w-1.5 h-1.5 rounded-full bg-[#ddd]"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-[#ddd]"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-[#ddd]"></div>
        </div>
        <div class="mockup-pages flex flex-col gap-0.5 p-0.5">
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[100px]"><div class="fill absolute inset-0 bg-[#e0e0e0]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[80px]"><div class="fill absolute inset-0 bg-[#e4e4e4]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[90px]"><div class="fill absolute inset-0 bg-[#e0e0e0]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[85px]"><div class="fill absolute inset-0 bg-[#e8e8e8]"></div></div>
          <div class="bg-bg-sub rounded-sm relative overflow-hidden h-[75px]"><div class="fill absolute inset-0 bg-[#e4e4e4]"></div></div>
        </div>
        <div class="absolute bottom-2 right-2 font-mono text-[9px] font-medium text-[#bbb] bg-white/80 px-1.5 py-0.5 rounded">streaming 3/5</div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="mx-auto max-w-3xl px-6 py-12 grid grid-cols-2 gap-5 max-[480px]:grid-cols-1">
    <div class="flex gap-3.5">
      <div class="w-9 h-9 rounded-lg bg-bg-sub border border-border flex items-center justify-center shrink-0">
        <svg class="text-fg3" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
      </div>
      <div>
        <h3 class="text-[13px] font-semibold leading-snug mb-0.5">Instant layout</h3>
        <p class="text-xs leading-relaxed text-fg3">Dimensions in the first 400 bytes. Zero CLS before any image loads.</p>
      </div>
    </div>
    <div class="flex gap-3.5">
      <div class="w-9 h-9 rounded-lg bg-bg-sub border border-border flex items-center justify-center shrink-0">
        <svg class="text-fg3" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </div>
      <div>
        <h3 class="text-[13px] font-semibold leading-snug mb-0.5">Random access</h3>
        <p class="text-xs leading-relaxed text-fg3">Fetch any page with a single HTTP Range request.</p>
      </div>
    </div>
    <div class="flex gap-3.5">
      <div class="w-9 h-9 rounded-lg bg-bg-sub border border-border flex items-center justify-center shrink-0">
        <svg class="text-fg3" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <div>
        <h3 class="text-[13px] font-semibold leading-snug mb-0.5">Progressive streaming</h3>
        <p class="text-xs leading-relaxed text-fg3">Pages render as data arrives. One request for the entire file.</p>
      </div>
    </div>
    <div class="flex gap-3.5">
      <div class="w-9 h-9 rounded-lg bg-bg-sub border border-border flex items-center justify-center shrink-0">
        <svg class="text-fg3" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      </div>
      <div>
        <h3 class="text-[13px] font-semibold leading-snug mb-0.5">No re-encoding</h3>
        <p class="text-xs leading-relaxed text-fg3">WebP, JPEG, JXL pass through as-is. Zero quality loss.</p>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-serif text-[28px] font-normal leading-tight text-center mb-6">Why not ZIP?</h2>
    <div class="border border-border rounded-lg overflow-hidden">
      <table class="w-full border-collapse text-[13px]">
        <tr>
          <th class="text-left font-medium text-fg p-2.5 px-4 bg-bg-sub border-b border-border"></th>
          <th class="text-left font-medium text-fg p-2.5 px-4 bg-bg-sub border-b border-border">MCZ</th>
          <th class="text-left font-medium text-fg p-2.5 px-4 bg-bg-sub border-b border-border">ZIP / CBZ</th>
          <th class="text-left font-medium text-fg p-2.5 px-4 bg-bg-sub border-b border-border">PDF</th>
        </tr>
        <tr><td class="p-2.5 px-4 border-b border-border font-medium text-fg">Index at start</td><td class="p-2.5 px-4 border-b border-border text-success">✓</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗ end</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗ scattered</td></tr>
        <tr><td class="p-2.5 px-4 border-b border-border font-medium text-fg">Layout before download</td><td class="p-2.5 px-4 border-b border-border text-success">✓</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td></tr>
        <tr><td class="p-2.5 px-4 border-b border-border font-medium text-fg">Random page access</td><td class="p-2.5 px-4 border-b border-border text-success">✓ Range</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗ unpack all</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗ complex</td></tr>
        <tr><td class="p-2.5 px-4 border-b border-border font-medium text-fg">Progressive streaming</td><td class="p-2.5 px-4 border-b border-border text-success">✓</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td><td class="p-2.5 px-4 border-b border-border text-fg3">✗</td></tr>
        <tr><td class="p-2.5 px-4 font-medium text-fg">Single HTTP request</td><td class="p-2.5 px-4 text-success">✓</td><td class="p-2.5 px-4 text-success">✓</td><td class="p-2.5 px-4 text-success">✓</td></tr>
      </table>
    </div>
  </section>

  <!-- Code -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-serif text-[28px] font-normal leading-tight text-center mb-6">Simple to use</h2>
    <div class="code-tabs flex gap-px mb-[-1px] relative z-10">
      <button class="code-tab font-mono text-[11px] font-medium px-3.5 py-2 border border-border rounded-t-lg cursor-pointer transition-colors hover:text-fg2 bg-white text-fg border-b-white" data-tab="0">TypeScript</button>
      <button class="code-tab font-mono text-[11px] font-medium px-3.5 py-2 border border-border rounded-t-lg cursor-pointer transition-colors hover:text-fg2 bg-bg-sub text-fg3" data-tab="1">Rust</button>
      <button class="code-tab font-mono text-[11px] font-medium px-3.5 py-2 border border-border rounded-t-lg cursor-pointer transition-colors hover:text-fg2 bg-bg-sub text-fg3" data-tab="2">CLI</button>
    </div>
    <pre class="code-pre bg-bg-sub border border-border rounded-[0_10px_10px_10px] p-4 px-5 font-mono text-xs leading-[1.7] text-fg overflow-x-auto"><span class="text-syn-kw">const</span> mcz = <span class="text-syn-kw">await</span> <span class="text-syn-fn">MCZ.open</span>(url)

mcz.pages  <span class="text-syn-cm italic">// dimensions available instantly</span>

<span class="text-syn-kw">for await</span> (<span class="text-syn-kw">const</span> {"{"} index, blob {"}"} <span class="text-syn-kw">of</span> mcz.<span class="text-syn-fn">stream</span>()) {"{"}
  document.<span class="text-syn-fn">querySelectorAll</span>(<span class="text-syn-str">"img"</span>)[index].src
    = URL.<span class="text-syn-fn">createObjectURL</span>(blob)
{"}"}</pre>
    <pre class="code-pre hidden bg-bg-sub border border-border rounded-[0_10px_10px_10px] p-4 px-5 font-mono text-xs leading-[1.7] text-fg overflow-x-auto"><span class="text-syn-kw">let</span> data = std::fs::<span class="text-syn-fn">read</span>(<span class="text-syn-str">"chapter.mcz"</span>)?;
<span class="text-syn-kw">let</span> index = mcz::<span class="text-syn-fn">read_index</span>(&amp;data)?;
<span class="text-syn-kw">let</span> page = mcz::<span class="text-syn-fn">extract_page</span>(&amp;data, &amp;index, 0)?;</pre>
    <pre class="code-pre hidden bg-bg-sub border border-border rounded-[0_10px_10px_10px] p-4 px-5 font-mono text-xs leading-[1.7] text-fg overflow-x-auto">mcz pack ./images -o chapter.mcz -q 80
mcz info chapter.mcz
mcz extract chapter.mcz 0 -o cover.webp</pre>
  </section>
</Base>

<style>
  @keyframes pg-fill { to { transform: scaleX(1) } }
  .mockup-pages .fill {
    transform: scaleX(0);
    transform-origin: left;
    animation: pg-fill .6s ease forwards;
  }
  .mockup-pages > :nth-child(1) .fill { animation-delay: .3s }
  .mockup-pages > :nth-child(2) .fill { animation-delay: .8s }
  .mockup-pages > :nth-child(3) .fill { animation-delay: 1.3s }
  .mockup-pages > :nth-child(4) .fill { animation-delay: 1.8s }
  .mockup-pages > :nth-child(5) .fill { animation-delay: 2.3s }
</style>

<script>
  document.querySelectorAll('.code-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const i = Number(tab.getAttribute('data-tab'));
      document.querySelectorAll('.code-tab').forEach((t, j) => {
        const active = j === i;
        t.classList.toggle('bg-white', active);
        t.classList.toggle('text-fg', active);
        t.classList.toggle('border-b-white', active);
        t.classList.toggle('bg-bg-sub', !active);
        t.classList.toggle('text-fg3', !active);
      });
      document.querySelectorAll('.code-pre').forEach((p, j) => {
        p.classList.toggle('hidden', j !== i);
      });
    });
  });
</script>
