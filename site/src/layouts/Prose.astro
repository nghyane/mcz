---
import "../styles/global.css";
import Base from "./Base.astro";
import Author from "../components/Author.astro";

interface Props {
  title: string;
  description?: string;
  date?: string;
  showAuthor?: boolean;
}

const { title, description, date, showAuthor = true } = Astro.props;
const siteUrl = 'https://mcz.pages.dev';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<Base title={`${title} — MCZ`} description={description}>
  {date && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": date,
      "author": { "@type": "Person", "name": "nghyane", "url": "https://github.com/nghyane" },
      "publisher": { "@type": "Organization", "name": "MCZ" },
      "url": canonicalUrl,
    })} />
  )}

  <article class="mx-auto max-w-xl px-6 py-16">
    {date && <time class="text-xs text-fg3 font-mono">{date}</time>}
    <h1 class="font-serif text-[32px] font-normal text-fg mt-2 mb-8">{title}</h1>
    <div class="prose text-sm leading-relaxed text-fg2
      [&_h2]:text-base [&_h2]:font-semibold [&_h2]:text-fg [&_h2]:mt-10 [&_h2]:mb-3
      [&_h3]:text-sm [&_h3]:font-semibold [&_h3]:text-fg [&_h3]:mt-8 [&_h3]:mb-2
      [&_p]:mb-4
      [&_a]:text-accent [&_a]:underline [&_a]:hover:no-underline
      [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-4
      [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:mb-4
      [&_li]:mb-1
      [&_strong]:text-fg
      [&_code]:font-mono [&_code]:text-xs [&_code]:bg-bg-sub [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded
      [&_pre]:bg-bg-sub [&_pre]:border [&_pre]:border-border [&_pre]:rounded-lg [&_pre]:p-4 [&_pre]:font-mono [&_pre]:text-xs [&_pre]:leading-relaxed [&_pre]:overflow-x-auto [&_pre]:mb-4
      [&_pre_code]:bg-transparent [&_pre_code]:p-0
      [&_table]:w-full [&_table]:border-collapse [&_table]:text-xs [&_table]:mb-6 [&_table]:border [&_table]:border-border [&_table]:rounded-lg [&_table]:overflow-hidden
      [&_th]:text-left [&_th]:font-medium [&_th]:text-fg [&_th]:p-2.5 [&_th]:px-3 [&_th]:bg-bg-sub [&_th]:border-b [&_th]:border-border
      [&_td]:p-2.5 [&_td]:px-3 [&_td]:border-b [&_td]:border-border
      [&_tr:last-child_td]:border-b-0
      [&_blockquote]:border-l-2 [&_blockquote]:border-border [&_blockquote]:pl-4 [&_blockquote]:text-fg3 [&_blockquote]:italic [&_blockquote]:mb-4
      [&_hr]:border-border [&_hr]:my-8
      [&_.tldr]:bg-bg-sub [&_.tldr]:border [&_.tldr]:border-border [&_.tldr]:rounded-lg [&_.tldr]:px-5 [&_.tldr]:py-4 [&_.tldr]:mb-6 [&_.tldr_p]:mb-0
      [&_.label]:text-[10px] [&_.label]:font-bold [&_.label]:uppercase [&_.label]:tracking-wider [&_.label]:bg-fg [&_.label]:text-white [&_.label]:px-1.5 [&_.label]:py-0.5 [&_.label]:rounded [&_.label]:align-middle [&_.label]:mr-1.5
    ">
      <slot />
    </div>
    {showAuthor && <Author />}
  </article>
</Base>
